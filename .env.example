# Copy to `.env` and uncomment ONE example below, then adjust. docker compose
# loads it automatically. Everything is optional — with no .env at all,
# compose.yml's defaults run Example 1 as-is.

# ----- Example 1 (default): dual-model — text-only brain + vision model ------
#MODEL_URL=http://10.0.0.55:8888/v1
#MODEL_ID=deepseek-v4-flash-dspark
#MODEL_NAME=DeepSeek V4 Flash DSpark
#MODEL_CONTEXT=1000000
#MODEL_MAX_TOKENS=16384
# false = the brain can't see images; the vision model below handles them
#MODEL_VISION=false
#VISION_MODEL_URL=http://10.0.0.13:8000/v1
#VISION_MODEL_ID=qwen3.6-35b
#VISION_MODEL_NAME=Qwen3.6 35B A3B
#VISION_MODEL_CONTEXT=120000
#VISION_MODEL_MAX_TOKENS=16384

# ----- Example 2: single model — one vision-capable model does everything ----
# Fill out the VISION_MODEL_* vars; MODEL_* just references them (compose
# interpolates ${VAR} inside .env files), so each value is written once.
#VISION_MODEL_URL=http://10.0.0.13:8000/v1
#VISION_MODEL_ID=qwen3.6-35b
#VISION_MODEL_NAME=Qwen3.6 35B A3B
#VISION_MODEL_CONTEXT=120000
#VISION_MODEL_MAX_TOKENS=16384
#MODEL_URL=${VISION_MODEL_URL}
#MODEL_ID=${VISION_MODEL_ID}
#MODEL_NAME=${VISION_MODEL_NAME}
#MODEL_CONTEXT=${VISION_MODEL_CONTEXT}
#MODEL_MAX_TOKENS=${VISION_MODEL_MAX_TOKENS}
#MODEL_VISION=true

# ----- Other ------------------------------------------------------------------
# Default tool at browser connect (claude | opencode | omp); empty = menu
#DEFAULT_TOOL=

# ----- Headroom (optional context-compression sidecar, issue #11) --------------
# Enable both lines together (litellm -> headroom -> reasoning-normalizer -> vLLM);
# details + gates: ideas/headroom-spike-results.md
#COMPOSE_PROFILES=headroom
#LITELLM_BRAIN_URL=http://agentic-headroom:8787/v1
